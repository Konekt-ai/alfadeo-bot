# ===== WhatsApp Cloud API (Meta Graph API v21) =====
# Token permanente (System User) o temporal de la app de Meta
WHATSAPP_TOKEN=
# ID del número de teléfono (Phone Number ID), NO el número visible
WHATSAPP_PHONE_NUMBER_ID=
# Token que tú inventas y registras en Meta para verificar el webhook (GET /webhook)
WHATSAPP_VERIFY_TOKEN=

# ===== Supabase =====
SUPABASE_URL=
# Service Role Key (NO la anon key). Tiene permisos completos: nunca la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Equipo interno =====
# Números del equipo separados por coma, formato internacional sin '+', ej: 5213312345678,5213398765432
INTERNAL_NOTIFY_NUMBERS=

# ===== Reglas de negocio =====
# Cantidad a partir de la cual se escala a una persona
ESCALA_CANTIDAD_UMBRAL=500

# ===== Servidor =====
# Railway inyecta PORT automáticamente; en local usa 3000
PORT=3000
